{
  "name": "@tlsn/host-extension",
  "version": "0.1.0",
  "description": "TLSNotary host adapter for Manifest-V3 browser extensions. Implements @tlsn/host-contracts via chrome.windows/webRequest (window + header interception), an offscreen-document tlsn-wasm prover, and the content-script DOM renderer.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./background": {
      "import": "./dist/background/index.js",
      "types": "./dist/background/index.d.ts"
    },
    "./content": {
      "import": "./dist/content/index.js",
      "types": "./dist/content/index.d.ts"
    },
    "./offscreen": {
      "import": "./dist/offscreen/index.js",
      "types": "./dist/offscreen/index.d.ts"
    },
    "./types": {
      "import": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./util": {
      "import": "./dist/util/index.js",
      "types": "./dist/util/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run lint:prettier && npm run lint:typescript",
    "lint:prettier": "prettier --check .",
    "lint:typescript": "tsc --noEmit",
    "lint:fix": "prettier --write ."
  },
  "dependencies": {
    "@tlsn/common": "*",
    "@tlsn/host-contracts": "*",
    "@tlsn/plugin-sdk": "*",
    "uuid": "^13.0.0"
  },
  "peerDependencies": {
    "comlink": ">=4",
    "tlsn-wasm": "*",
    "webextension-polyfill": ">=0.10"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.5",
    "@types/uuid": "^10.0.0",
    "@types/webextension-polyfill": "^0.12.5",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.0.11",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.0.16"
  }
}
