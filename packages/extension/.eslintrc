{
  "env": {
    "webextensions": true
  },
  "rules": {
    "@typescript-eslint/no-var-requires": "off",
    "@typescript-eslint/ban-ts-comment": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "no-undef": "error",
    "no-useless-escape": "off",
    "padding-line-between-statements": "error"
  },
  "globals": {
    "URLPattern": "readonly"
  },
  "settings": {
    "import/resolver": "typescript"
  },
  "ignorePatterns": [
    "zip",
    "wasm",
    "tlsn",
    "util",
    "lib",
    "plugins",
    "webpack.config.js"
  ]
}
