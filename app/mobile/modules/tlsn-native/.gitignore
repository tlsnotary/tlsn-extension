# Native build artifacts. Kept out of git; regenerated by
# build-ios.sh / build-android.sh. EAS packaging picks them
# up from disk because app/mobile/.easignore intentionally
# omits these paths — without that override, EAS would honor
# this .gitignore and the Kotlin/Swift bridge would fail to
# compile against the missing uniffi bindings.

# iOS
ios/TlsnMobile.xcframework/
ios/tlsn_mobile.swift
ios/lib/
ios/include/

# Android
android/src/main/jniLibs/
android/src/main/java/uniffi/
