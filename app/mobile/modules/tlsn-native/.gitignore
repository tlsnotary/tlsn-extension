# Native build artifacts are committed to the repo so that
# EAS Build can include them (EAS can't run cargo/Rust).
# Regenerate with build-ios.sh / build-android.sh if updating Rust code.

# iOS
# ios/TlsnMobile.xcframework/
# ios/tlsn_mobile.swift
ios/lib/
ios/include/

# Android
# android/src/main/jniLibs/
# android/src/main/java/uniffi/
