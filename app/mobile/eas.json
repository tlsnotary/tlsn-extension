{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true,
        "buildConfiguration": "Debug"
      },
      "env": {
        "EX_DEV_CLIENT_NETWORK_INSPECTOR": "false"
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    },
    "ci-android": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_DOCTOR_SKIP_DEPENDENCY_VERSION_CHECK": "1"
      }
    },
    "ci-ios": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_DOCTOR_SKIP_DEPENDENCY_VERSION_CHECK": "1"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6763331949"
      }
    }
  }
}
