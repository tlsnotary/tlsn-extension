{
  "expo": {
    "name": "TLSNotary Mobile",
    "slug": "tlsn-mobile",
    "version": "0.1.1400",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tlsn-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#243F5F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "org.tlsnotary.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#243F5F"
      },
      "edgeToEdgeEnabled": true,
      "package": "org.tlsnotary.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": ["expo-router", "./plugins/exclude-x86_64", "./plugins/adi-registration"],
    "experiments": {
      "typedRoutes": true
    },
    "assetBundlePatterns": ["assets/**/*"],
    "owner": "tlsnotary",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3f40d3ca-e5a6-45bb-88e9-32e4b9ab7f2f"
      }
    }
  }
}
